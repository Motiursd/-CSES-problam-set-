#include <iostream>
#include <string>
#include <map>

using namespace std;

int main() {
    int n;
    cin >> n;

    
    map<string, bool> visited;

    for (int i = 0; i < n; i++) {
        string name;
        cin >> name;

        
        if (visited[name]) {
            cout << "YES" << endl;
        } else {
            cout << "NO" << endl;
            
            visited[name] = true;
        }
    }

    return 0;
}
